# Copy to .env and edit. Used by docker-compose.platform.yml.

# --- API ---
# Local/dev only: accept insecure built-in defaults for the secrets below.
# Set to 0 (and fill in real values) before exposing the stack anywhere.
SECUREOPS_DEV_MODE=1
# HMAC secret for session JWTs. Generate: openssl rand -hex 32
SECUREOPS_JWT_SECRET=change-me-openssl-rand-hex-32
# Vendor Ed25519 public key (base64url, 32 bytes) that license keys are signed by.
# Blank + SECUREOPS_DEV_MODE=1 → built-in dev key (local only - NEVER in production).
SECUREOPS_LICENSE_PUBKEY=
# Comma-separated browser origins allowed to call the API cross-origin.
# Leave blank when the dashboard is served by the API itself (same origin).
SECUREOPS_CORS_ORIGINS=

# --- Postgres ---
POSTGRES_USER=secureops_app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=secureops

# --- MinIO (S3-compatible evidence store) ---
MINIO_ROOT_USER=secureops
MINIO_ROOT_PASSWORD=change-me-min-8-chars
